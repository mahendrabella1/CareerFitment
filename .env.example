# Public — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — NEVER expose to the browser or commit this value.
# Used by API routes (lib/supabase/client.ts -> getSupabaseAdmin) to bypass
# RLS when generating sessions and writing responses/scores.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin dashboard access token (/admin + GET /api/leads). Change this for
# production; if unset, defaults to "onegrasp-admin-dev".
ADMIN_TOKEN=change-me-to-a-long-random-string

# ---------------------------------------------------------------------------
# Firebase / Firestore (questions + leads). EASIEST: skip these and just drop
# the downloaded key file at project/serviceAccountKey.json instead.
# Otherwise paste the three values from that JSON here. Keep the quotes on the
# private key; the literal \n sequences are converted to real newlines at load.
# ---------------------------------------------------------------------------
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ---------------------------------------------------------------------------
# Firebase WEB config (PUBLIC — safe to expose) for user accounts (Auth +
# Firestore). Get these from Firebase console -> Project settings -> Your apps
# -> Web app -> SDK setup and configuration. Required for /register, /signin,
# /account to actually work. Also enable Email/Password in Authentication.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=your-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=careerfitment.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=careerfitment
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=careerfitment.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# ---------------------------------------------------------------------------
# SMTP for emailing reports from /admin (Hostinger). Add the REAL values in
# Vercel -> Settings -> Environment Variables and in a local .env.local.
# NEVER commit the real password.
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=support@onegrasp.com
SMTP_PASS=your-smtp-password
