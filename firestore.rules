rules_version = '2';

// Firestore security rules for user accounts.
// Deploy from the Firebase console (Firestore -> Rules) or `firebase deploy
// --only firestore:rules`.
service cloud.firestore {
  match /databases/{database}/documents {

    // Each signed-in user may read/write ONLY their own profile document.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Everything else denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
