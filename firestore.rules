rules_version = '2';

// Firestore security rules for user accounts.
// Deploy from the Firebase console (Firestore -> Rules) or `firebase deploy
// --only firestore:rules`.
service cloud.firestore {
  match /databases/{database}/documents {

    // Admins (keep in sync with lib/auth/admins.ts) may read every profile.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in ['support@onegrasp.com'];
    }

    // A user may read/write their OWN profile; admins may read all profiles.
    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Everything else denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
